# XML-RPC over SCGI endpoint of the local rtorrent instance.
#   scgi://127.0.0.1:5000    → TCP (rutorrent default)
#   scgi:///tmp/rtorrent.sock → unix socket
RTORRENT_SCGI_URL=scgi://127.0.0.1:5000
RTORRENT_TIMEOUT_SECONDS=30.0

# Defaults for the "kind" hint in add_torrent. Absolute paths, must exist
# on the same host rtorrent runs on.
RTORRENT_DOWNLOAD_DIR_MOVIES=/mnt/storage/Media/Video/Movie/
RTORRENT_DOWNLOAD_DIR_SERIES=/mnt/storage/Media/Video/Series/

# Transport-level Bearer token used by networked MCP clients.
# Leave empty for stdio-only development.
MCP_AUTH_TOKEN=

# MCP transport — one of: stdio, sse, streamable-http.
MCP_TRANSPORT=streamable-http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8768
